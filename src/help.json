{
  "title": "Wave Edit",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Edit WAV files on",
        "your Move. Trim,",
        "adjust gain, mute,",
        "copy/paste, and",
        "normalize audio.",
        "",
        "Waveform display with",
        "zoom and minimap.",
        "Undo support for all",
        "destructive edits."
      ]
    },
    {
      "title": "Navigation",
      "lines": [
        "Jog: move selected",
        "  marker (start/end)",
        "Jog click: toggle",
        "  between start and",
        "  end markers",
        "",
        "E1 (Knob 1): move",
        "  start marker",
        "E2 (Knob 2): move",
        "  end marker",
        "E3 (Knob 3): zoom",
        "  Shift: vertical",
        "  scale (1x-32x)"
      ]
    },
    {
      "title": "Editing",
      "lines": [
        "E4 (Knob 4): gain",
        "  Shift: normalize",
        "",
        "Mute: zero selection",
        "Copy: copy selection",
        "Shift+Copy: paste",
        "  (insert at cursor)",
        "Delete: cut selection",
        "  (copy + remove)",
        "",
        "Undo: undo last edit",
        "All edits reversible."
      ]
    },
    {
      "title": "Playback",
      "lines": [
        "Any pad: hold to",
        "  audition selection",
        "  release to stop",
        "",
        "Shift+Pad: play",
        "  entire file",
        "",
        "Loop button: toggle",
        "  loop mode on/off",
        "",
        "Header shows:",
        " * = unsaved changes",
        " L = loop enabled"
      ]
    },
    {
      "title": "Slice Mode",
      "lines": [
        "Capture: enter/exit",
        "  slice mode",
        "",
        "Jog: navigate footer",
        "  items (Mode, Count,",
        "  Select)",
        "Jog click: toggle",
        "  edit/navigate mode",
        "",
        "E1: adjust slice start",
        "E2: adjust slice end",
        "E3: zoom  Shift: scale",
        "",
        "Modes: Even (fixed",
        "  count) or Auto",
        "  (transient detect)",
        "",
        "Pads: select + play",
        "  slice (hold to",
        "  audition)",
        "Left/Right: prev/next",
        "  slice",
        "Up/Down: scroll pad",
        "  banks (>32 slices)",
        "",
        "Sample: export slices",
        "  as WAVs, Drum Kit",
        "  preset, or REX loop",
        "Back: return to Edit"
      ]
    },
    {
      "title": "Saving",
      "lines": [
        "Capture: save file",
        "  (overwrite confirm)",
        "",
        "Shift+Capture: export",
        "  selection to a",
        "  new file",
        "",
        "Back: exit (warns if",
        "  unsaved changes)"
      ]
    }
  ]
}
