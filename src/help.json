{
  "title": "Wave Edit",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Edit WAV files on",
        "your Move. Trim,",
        "adjust gain, mute,",
        "copy/paste, and",
        "normalize audio.",
        "",
        "Waveform display with",
        "zoom and minimap.",
        "Undo support for all",
        "destructive edits."
      ]
    },
    {
      "title": "Navigation",
      "lines": [
        "Jog: move selected",
        "  marker (start/end)",
        "Jog click: toggle",
        "  between start and",
        "  end markers",
        "",
        "E1 (Knob 1): move",
        "  start marker",
        "E2 (Knob 2): move",
        "  end marker",
        "E3 (Knob 3): zoom",
        "  Shift: vertical",
        "  scale (1x-32x)",
        "",
        "Left/Right: nudge",
        "  selection by one",
        "  coarse step",
        "Shift+L/R: jump by",
        "  one selection length"
      ]
    },
    {
      "title": "Editing",
      "lines": [
        "E4 (Knob 4): gain",
        "  Shift: normalize",
        "",
        "Mute: zero selection",
        "Copy: copy selection",
        "Shift+Copy: paste",
        "  (insert at cursor)",
        "Delete: cut selection",
        "  (copy + remove)",
        "",
        "Undo: undo last edit",
        "All edits reversible."
      ]
    },
    {
      "title": "Playback",
      "lines": [
        "Any pad: hold to",
        "  audition selection",
        "  release to stop",
        "",
        "Shift+Pad: preview",
        "  near end marker",
        "",
        "Shift+Loop: toggle",
        "  loop mode on/off",
        "",
        "Header shows:",
        " * = unsaved changes",
        " L = loop enabled"
      ]
    },
    {
      "title": "Loop View",
      "lines": [
        "Loop: enter loop view",
        "  (seam editor for",
        "  seamless loops)",
        "",
        "E1: adjust loop point",
        "E2: adjust loop end",
        "E3: zoom seam view",
        "  Shift: vert scale",
        "Jog click: toggle",
        "  loop point / end",
        "",
        "Shift+Loop: snap to",
        "  zero crossing",
        "Loop: return to edit"
      ]
    },
    {
      "title": "Slice Mode",
      "lines": [
        "Capture: enter/exit",
        "  slice mode",
        "",
        "Jog: navigate footer",
        "  items (Mode, Count,",
        "  Select)",
        "Jog click: toggle",
        "  edit/navigate mode",
        "",
        "E1: adjust slice start",
        "E2: adjust slice end",
        "E3: zoom  Shift: scale",
        "E4: threshold (Auto)",
        "  Shift: fine (0.1)",
        "",
        "Modes: Even (fixed",
        "  count), Auto",
        "  (transient detect),",
        "  or Lazy (real-time",
        "  chop, SP-2400 style)",
        "",
        "Pads: select + play",
        "  slice (hold to",
        "  audition)",
        "Left/Right: prev/next",
        "  slice",
        "Down: split slice at",
        "  midpoint",
        "Up: merge with previous",
        "  slice",
        "Shift+Up/Down: scroll",
        "  pad banks (>32)"
      ]
    },
    {
      "title": "Lazy Chop",
      "lines": [
        "In Slice mode, select",
        "Lazy mode. Sub-modes:",
        "",
        "Chop: press Pad 1 to",
        "  start playback.",
        "  Press again to add",
        "  chop points in",
        "  real time. Playback",
        "  ends at file end",
        "  or press Capture.",
        "",
        "Play: audition slices",
        "  with pads after",
        "  chopping is done.",
        "",
        "Jog on Count toggles",
        "  Chop / Play sub-mode."
      ]
    },
    {
      "title": "Recording",
      "lines": [
        "Open File browser:",
        "  select New Recording",
        "  to create a new file",
        "",
        "Records Move's audio",
        "  output (resample).",
        "",
        "REC LED flashes when",
        "  armed. Press REC to",
        "  start recording.",
        "Press REC again to",
        "  stop. File loads",
        "  into editor.",
        "",
        "Back: cancel and",
        "  return to browser"
      ]
    },
    {
      "title": "Saving",
      "lines": [
        "Sample: save file",
        "  (overwrite confirm)",
        "",
        "Shift+Capture: export",
        "  selection to a",
        "  new file",
        "",
        "In Slice mode, Sample",
        "  offers: Slices,",
        "  Drum Preset, or",
        "  REX Loop (if Rex",
        "  module installed)",
        "",
        "Back: exit (warns if",
        "  unsaved changes)"
      ]
    }
  ]
}
